#!/usr/bin/env bash
# Cortex CLI вАФ Hermes integration
# Usage: cortex <command> [args...]
# Hermes can call this via terminal tool to interact with Cortex workspace.

BASE_URL="${CORTEX_URL:-http://localhost:3000}"

cmd="$1"
shift

case "$cmd" in
  note)
    sub="$1"; shift
    case "$sub" in
      list)
        curl -s "$BASE_URL/api/notes${*:+?q=$*}" | python3 -c "
import json,sys
data=json.load(sys.stdin)
if isinstance(data, list):
  for n in data:
    print(f\"  [{n['id']}] {n['title']}\")
else:
  print(data)
"
        ;;
      create)
        title="$1"; content="$2"
        curl -s -X POST "$BASE_URL/api/notes" \
          -H "Content-Type: application/json" \
          -d "{\"title\":\"$title\",\"content\":\"$content\"}"
        ;;
      get)
        curl -s "$BASE_URL/api/notes?id=$1" | python3 -c "
import json,sys
data=json.load(sys.stdin)
if 'content' in data:
  print(f\"# {data['title']}\n\n{data['content']}\")
else:
  print(json.dumps(data, indent=2))
"
        ;;
      delete)
        curl -s -X DELETE "$BASE_URL/api/notes?id=$1"
        ;;
      search)
        curl -s "$BASE_URL/api/notes?q=$*" | python3 -c "
import json,sys
data=json.load(sys.stdin)
for n in data:
  print(f\"  [{n['id']}] {n['title']}\")
"
        ;;
      *)
        echo "Usage: cortex note <list|create|get|delete|search> [args]"
        ;;
    esac
    ;;

  obsidian)
    sub="$1"
    case "$sub" in
      sync)
        vault="${2:-}"
        curl -s -X POST "$BASE_URL/api/obsidian-sync" \
          -H "Content-Type: application/json" \
          -d "{\"action\":\"sync\",\"path\":\"$vault\"}"
        ;;
      *)
        echo "Usage: cortex obsidian sync [vault-path]"
        ;;
    esac
    ;;

  courses)
    curl -s "$BASE_URL/api/courses" 2>/dev/null || echo "[]"
    ;;

  ask)
    question="$*"
    if [[ -z "$question" ]]; then
      echo "Usage: cortex ask <question>"
      exit 1
    fi
    curl -s -X POST "$BASE_URL/api/orchestrator" \
      -H "Content-Type: application/json" \
      -d "{\"question\":\"$question\"}" | python3 -c "
import json,sys
d=json.load(sys.stdin)
print(d.get('answer', d.get('error', 'No answer')))
"
    ;;

  inbox)
    sub="$1"; shift
    case "$sub" in
      list)
        status="${1:-new}"
        curl -s "$BASE_URL/api/inbox?status=$status" | python3 -c "
import json,sys
data=json.load(sys.stdin)
for item in data:
  summary = item.get('summary','')
  short = (summary[:80] + '...') if summary and len(summary) > 80 else summary
  print(f\"  [{item['id']}] {item['title']}\")
  if short:
    print(f\"       {short}\")
  print()
"
        ;;
      add)
        title="$1"; shift
        url=""; source="article"
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --url) url="$2"; shift 2 ;;
            --type) source="$2"; shift 2 ;;
            *) shift ;;
          esac
        done
        body="{\"title\":\"$title\",\"sourceType\":\"$source\""
        [[ -n "$url" ]] && body="$body,\"url\":\"$url\""
        body="$body}"
        curl -s -X POST "$BASE_URL/api/inbox" \
          -H "Content-Type: application/json" \
          -d "$body"
        echo ""
        ;;
      process)
        id="$1"
        curl -s -X PATCH "$BASE_URL/api/inbox" \
          -H "Content-Type: application/json" \
          -d "{\"id\":$id,\"action\":\"process\"}" | python3 -c "
import json,sys
d=json.load(sys.stdin)
if d.get('ok'):
  print(f\"вЬЕ Processed: {d.get('summary','')[:200]}\")
  for i in d.get('insights', []):
    print(f'  рЯТ° {i}')
else:
  print(f\"вЭМ Error: {d.get('error', 'unknown')}\")
"
        ;;
      archive)
        id="$1"
        curl -s -X PATCH "$BASE_URL/api/inbox" \
          -H "Content-Type: application/json" \
          -d "{\"id\":$id,\"action\":\"archive\"}"
        echo "Archived #$id"
        ;;
      delete)
        id="$1"
        curl -s -X DELETE "$BASE_URL/api/inbox?id=$id"
        echo "Deleted #$id"
        ;;
      *)
        echo "Usage: cortex inbox <list|add|process|archive|delete> [args]"
        echo "  cortex inbox list [status]      List items"
        echo "  cortex inbox add <title>        Add item"
        echo "    --url https://... --type article|podcast|email|youtube"
        echo "  cortex inbox process <id>       AI-process item"
        echo "  cortex inbox archive <id>       Archive item"
        echo "  cortex inbox delete <id>        Delete item"
        ;;
    esac
    ;;

  briefing)
    curl -s "$BASE_URL/api/briefing" | python3 -c "
import json,sys
d=json.load(sys.stdin)
print(f\"{d['greeting']}, –Х–≤–≥–µ–љ–Є–є! ({d['date']})\\n\")

# Streak
s=d.get('streak')
if s:
  print(f\"рЯФ• –°–µ–≥–Њ–і–љ—П: {s['current']} –Љ–Њ–і—Г–ї–µ–є, {s['minutes']} –Љ–Є–љ\" if s['current'] > 0 else 'рЯФ• –°–µ–≥–Њ–і–љ—П –µ—Й—С –љ–µ –Ј–∞–љ–Є–Љ–∞–ї—Б—П')
else:
  print('рЯФ• –°–µ–≥–Њ–і–љ—П –µ—Й—С –љ–µ –Ј–∞–љ–Є–Љ–∞–ї—Б—П')
print()

# Courses
courses=d.get('courses',{}).get('active',[])
if courses:
  print('рЯУЪ –Ъ–£–†–°–Ђ:')
  for c in courses:
    bar='вЦИ'*(c['progress']//10)+'вЦС'*(10-c['progress']//10)
    print(f'  [{bar}] {c[\"progress\"]}% {c[\"title\"]}')
  print()

# Tasks
tasks=d.get('tasks',{})
overdue=tasks.get('overdue',[])
today=tasks.get('today',[])
if overdue:
  print(f'вЪ†пЄП  –Я–†–Ю–°–†–Ю–І–Х–Э–Ю ({len(overdue)}):')
  for t in overdue:
    prio={1:'рЯФ•',2:'вЧП',3:'вЧЛ'}.get(t.get('priority',2),'вЧЛ')
    print(f'  {prio} {t[\"title\"]}')
  print()
if today:
  print(f'рЯУЛ –Э–Р –°–Х–У–Ю–Ф–Э–ѓ ({len(today)}):')
  for t in today:
    prio={1:'рЯФ•',2:'вЧП',3:'вЧЛ'}.get(t.get('priority',2),'вЧЛ')
    print(f'  {prio} {t[\"title\"]}')
  print()

# Events
events=d.get('events',[])
if events:
  print(f'рЯУЕ –°–Ю–С–Ђ–Ґ–Ш–ѓ ({len(events)}):')
  for e in events:
    print(f'  {e[\"title\"]}')
  print()

# Notes
notes=d.get('notes',{}).get('recent',[])
if notes:
  print(f'рЯУЭ –Я–Ю–°–Ы–Х–Ф–Э–Ш–Х –Ч–Р–Ь–Х–Ґ–Ъ–Ш:')
  for n in notes:
    print(f'  {n[\"title\"]}')
  print()

# Inbox
inbox_count=d.get('inbox',{}).get('unprocessed',0)
if inbox_count > 0:
  print(f'рЯУ• –Т—Е–Њ–і—П—Й–Є—Е: {inbox_count} –љ–µ–Њ–±—А–∞–±–Њ—В–∞–љ–Њ')

# Knowledge
insights=d.get('knowledge',{}).get('recentInsights',[])
if insights:
  print(f'\\nрЯТ° –°–Т–Х–Ц–Ш–Х –Ш–Э–°–Р–Щ–Ґ–Ђ:')
  for ins in insights:
    print(f'  вЧП {ins[\"content\"]}')
"
    ;;

  task)
    sub="$1"; shift
    case "$sub" in
      list)
        status="${1:-}"
        curl -s "$BASE_URL/api/tasks${status:+?status=$status}" | python3 -c "
import json,sys
data=json.load(sys.stdin)
for t in data:
  prio={1:'рЯФ•',2:'вЧП',3:'вЧЛ'}.get(t.get('priority',2),'вЧЛ')
  status_map={'todo':'вШР','in_progress':'вЦґ','done':'вЬУ','cancelled':'вЬЧ'}
  st=status_map.get(t.get('status','todo'),'?')
  due=f\" рЯУЕ{t['dueDate']}\" if t.get('dueDate') else ''
  print(f\"  [{t['id']}] {prio} {st} {t['title']}{due}\")
"
        ;;
      create)
        title="$1"; shift
        due=""; priority=""; status="todo"
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --due) due="$2"; shift 2 ;;
            --priority) priority="$2"; shift 2 ;;
            --status) status="$2"; shift 2 ;;
            *) shift ;;
          esac
        done
        body="{\"title\":\"$title\""
        [[ -n "$due" ]] && body="$body,\"dueDate\":\"$due\""
        [[ -n "$priority" ]] && body="$body,\"priority\":$priority"
        [[ "$status" != "todo" ]] && body="$body,\"status\":\"$status\""
        body="$body}"
        curl -s -X POST "$BASE_URL/api/tasks" \
          -H "Content-Type: application/json" \
          -d "$body" | python3 -c "
import json,sys
t=json.load(sys.stdin)
print(f\"Created task #{t['id']}: {t['title']}\")
"
        ;;
      done)
        id="$1"
        curl -s -X PATCH "$BASE_URL/api/tasks/$id" \
          -H "Content-Type: application/json" \
          -d '{"status":"done"}'
        echo "Task #$id marked as done"
        ;;
      undo)
        id="$1"
        curl -s -X PATCH "$BASE_URL/api/tasks/$id" \
          -H "Content-Type: application/json" \
          -d '{"status":"todo"}'
        echo "Task #$id moved back to todo"
        ;;
      delete)
        id="$1"
        curl -s -X DELETE "$BASE_URL/api/tasks/$id"
        echo "Task #$id deleted"
        ;;
      *)
        echo "Usage: cortex task <list|create|done|undo|delete> [args]"
        echo "  cortex task list [status]       List tasks (filter by status)"
        echo "  cortex task create <title>      Create task"
        echo "    --due 2026-06-10 --priority 1 --status in_progress"
        echo "  cortex task done <id>           Mark as done"
        echo "  cortex task undo <id>           Move back to todo"
        echo "  cortex task delete <id>         Delete task"
        ;;
    esac
    ;;

  today)
    curl -s "$BASE_URL/api/today" | python3 -c "
import json,sys
d=json.load(sys.stdin)
print(f\"=== рЯУЕ {d['date']} ===\n\")

# Streak
s=d.get('streak')
if s:
  print(f\"рЯФ• Streak: {s['modules']} –Љ–Њ–і—Г–ї–µ–є, {s['minutes']} –Љ–Є–љ\n\")

# Tasks
today_tasks=d['tasks']['today']
overdue=d['tasks']['overdue']
if overdue:
  print('вЪ†пЄП  –Я–†–Ю–°–†–Ю–І–Х–Э–Ю:')
  for t in overdue:
    prio={1:'рЯФ•',2:'вЧП',3:'вЧЛ'}.get(t.get('priority',2),'вЧЛ')
    print(f'  [{t[\"id\"]}] {prio} {t[\"title\"]}')
  print()

if today_tasks:
  print('рЯУЛ –Э–Р –°–Х–У–Ю–Ф–Э–ѓ:')
  for t in today_tasks:
    prio={1:'рЯФ•',2:'вЧП',3:'вЧЛ'}.get(t.get('priority',2),'вЧЛ')
    print(f'  [{t[\"id\"]}] {prio} {t[\"title\"]}')
else:
  print('рЯУЛ –Ч–∞–і–∞—З –љ–∞ —Б–µ–≥–Њ–і–љ—П –љ–µ—В')

# Events
events=d['events']
if events:
  print(f'\\nрЯУЕ –°–Ю–С–Ђ–Ґ–Ш–ѓ ({len(events)}):')
  for e in events:
    print(f'  {e[\"title\"]}')
print()

# Courses
courses=d['courses']
if courses:
  print('рЯУЪ –Ъ–£–†–°–Ђ:')
  for c in courses:
    print(f'  [{c[\"progress\"]}%] {c[\"title\"]}')
"
    ;;

  *)
    echo "Cortex CLI вАФ Personal Workspace"
    echo ""
    echo "Commands:"
    echo "  cortex note list [query]        List/search notes"
    echo "  cortex note create <title> <md> Create note"
    echo "  cortex note get <id>            Read note"
    echo "  cortex note delete <id>         Delete note"
    echo "  cortex note search <query>      Search notes"
    echo "  cortex obsidian sync [path]     Sync Obsidian vault"
    echo "  cortex courses                  List courses"
    echo "  cortex task list [status]       List tasks"
    echo "  cortex task create <title>      Create task"
    echo "  cortex task done <id>           Mark task done"
    echo "  cortex today                    Today's briefing"
    echo "  cortex ask <question>           Ask Hermes (with workspace context)"
    echo "  cortex inbox list [status]      List inbox items"
    echo "  cortex inbox add <title>        Add to inbox"
    echo "  cortex inbox process <id>       AI-process inbox item"
    echo "  cortex briefing                 Daily Briefing 2.0"
    echo ""
    echo "Env: CORTEX_URL (default http://localhost:3000)"
    ;;
esac
